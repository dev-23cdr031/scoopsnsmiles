# Copy this file to .env before deployment and update values.

# MySQL credentials used by db and backend services
MYSQL_ROOT_PASSWORD=replace_with_a_strong_root_password
MYSQL_DATABASE=sakthi_bakers
MYSQL_USER=sakthi
MYSQL_PASSWORD=replace_with_a_strong_app_password

# Optional: use an external cloud DB instead of compose db service
# DATABASE_URL=mysql://user:password@host:3306/sakthi_bakers
DATABASE_URL=
# Optional SSL for managed cloud MySQL (set true/required if needed)
DB_SSL=false

# Frontend URL allowed by backend CORS (comma-separated if needed)
# Example: https://bakery.example.com,https://www.bakery.example.com
FRONTEND_ORIGIN=https://bakery.example.com

# Public API URL consumed by the frontend at build/runtime
# Use your backend public URL in production
NEXT_PUBLIC_API_BASE_URL=https://api.bakery.example.com

# Optional: deployed ML backend URL used by backend /api/admin/ml/insights
# Example: https://sakthi-ml.onrender.com
ML_API_BASE_URL=
