# MySQL connection settings (cloud or local)
# Prefer DATABASE_URL for cloud providers.
DATABASE_URL=
# Optional alias if your provider gives MYSQL_URL instead.
MYSQL_URL=

# Optional SSL toggle for managed DBs (true/false)
DB_SSL=false

# Fallback discrete fields (used if DATABASE_URL/MYSQL_URL is empty)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sakthi_bakers

# Optional deployed Python ML API base URL (example: https://sakthi-ml.onrender.com)
ML_API_BASE_URL=

PORT=5000
FRONTEND_ORIGIN=http://localhost:3000
