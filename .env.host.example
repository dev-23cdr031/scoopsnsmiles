# Copy this file to .env.host and fill all values before deploying on a VPS.

# Domains (must already point A records to your VPS public IP)
APP_DOMAIN=bakery.example.com
API_DOMAIN=api.bakery.example.com

# Backend CORS allow-list (comma-separated if needed)
FRONTEND_ORIGIN=https://bakery.example.com

# Public API URL used by Next.js
NEXT_PUBLIC_API_BASE_URL=https://api.bakery.example.com

# MySQL credentials
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
MYSQL_DATABASE=sakthi_bakers
MYSQL_USER=sakthi
MYSQL_PASSWORD=replace_with_strong_app_password

# Optional: external cloud MySQL URI. If set, backend can use this instead of db container.
# DATABASE_URL=mysql://user:password@host:3306/sakthi_bakers
DATABASE_URL=
DB_SSL=false

# Optional: deployed Python ML backend URL
ML_API_BASE_URL=
